{
  "name": "jy-data-ui-kit",
  "version": "0.1.0",
  "description": "Professional data visualization and management React components",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup && tsc --emitDeclarationOnly --noCheck",
    "dev": "tsup --watch"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0",
    "styled-components": "^6.0.0",
    "lucide-react": ">=0.400.0",
    "recharts": "^2.10.0"
  },
  "dependencies": {
    "clsx": "^2.0.0",
    "tailwind-merge": "^2.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0"
  },
  "keywords": [
    "react",
    "data-table",
    "chart",
    "data-visualization",
    "tree-view",
    "typescript"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/xxcordeau/jy-data-ui-kit"
  },
